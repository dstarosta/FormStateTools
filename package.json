{
  "author": {
    "name": "Dmitry Starosta"
  },
  "files": [
    "src",
    "dist"
  ],
  "license": "MIT",
  "name": "form-state-tools",
  "main": "dist/index.mjs",
  "sideEffects": false,
  "type": "module",
  "types": "dist/index.d.ts",
  "version": "1.0.0",
  "scripts": {
    "check-ts": "node -e \"const v=require('typescript').version; if(v<'5.9.0'){console.error('❌ TS version '+v+' is too low. Need >= 5.9.0');process.exit(1)}\"",
    "build": "npm i && npm run prettier && npm run check-ts && npm run typecheck && npm run lint && npm run test && tsdown && tsdown --config tsdown.types.config.ts",
    "lint": "eslint .",
    "prettier": "prettier -c src/**",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage"
  },
  "engines": {
    "node": ">= 24",
    "tsc": ">= 5.9.0"
  },
  "peerDependencies": {
    "lodash-es": ">= 4.17.21",
    "react": ">= 19.2.0",
    "react-dom": ">= 19.2.0",
    "zod": ">= 4.3.0 < 5.0.0"
  },
  "dependencies": {
    "form-state": "github:dstarosta/FormState#v1.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-babel": "^7.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "react-json-tree": "^0.20.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "eslint-plugin-react": {
      "eslint": ">= 9"
    },
    "eslint-plugin-react-hooks": {
      "eslint": ">= 9"
    }
  }
}
